{
  "manifest_version": 3,
  "name": "Student Buddy (LeetCode)",
  "description": "Mentor-style guidance while solving LeetCode problems",
  "version": "0.1",
  "permissions": ["activeTab", "scripting","storage"],
  "host_permissions": ["https://leetcode.com/*"],
  "content_scripts": [
    {
      "matches": ["https://leetcode.com/problems/*"],
      "js": ["content.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  }
}
